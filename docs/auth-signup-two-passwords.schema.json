{
  "schemaVersion": 1,
  "signUp": {
    "title": "Create new account",
    "submitLabel": "Sign up",
    "fields": [
      {
        "id": "email",
        "type": "email",
        "label": "Email Address",
        "placeholder": "Enter your email address",
        "required": true
      },
      {
        "id": "password",
        "type": "password",
        "label": "Password",
        "placeholder": "Enter your password",
        "required": true,
        "minLength": 8
      },
      {
        "id": "confirmPassword",
        "type": "password",
        "label": "Confirm Password",
        "placeholder": "Enter your confirm password",
        "required": true,
        "matches": "password"
      }
    ]
  }
}
